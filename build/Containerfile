ARG PYTHON_VERSION=3.14.2
ARG DEBIAN_BASE=bookworm
ARG REGISTRY_MIRROR
FROM ${REGISTRY_MIRROR:-}python:${PYTHON_VERSION}-slim-${DEBIAN_BASE} AS base

COPY build/resources/nginx-template.conf /templates/nginx/frappe.conf.template
COPY build/resources/nginx-entrypoint.sh /usr/local/bin/nginx-entrypoint.sh
COPY build/resources/security_headers.conf /etc/nginx/snippets/security_headers.conf
COPY build/resources/configurator-init.sh /usr/local/bin/configurator-init.sh

ARG WKHTMLTOPDF_VERSION=0.12.6.1-3
ARG WKHTMLTOPDF_DISTRO=bookworm
ARG NODE_VERSION=24.13.0
ENV NVM_DIR=/home/frappe/.nvm
ENV PATH=${NVM_DIR}/versions/node/v${NODE_VERSION}/bin/:${PATH}

# Mirror configuration for China deployment (leave empty to use defaults)
ARG APT_MIRROR
ARG PIP_INDEX_URL
ARG PIP_TRUSTED_HOST
ARG NPM_REGISTRY
ARG NVM_INSTALL_SCRIPT=https://raw.githubusercontent.com/nvm-sh/nvm/v0.39.5/install.sh
ARG NODE_MIRROR
ARG WKHTMLTOPDF_MIRROR=https://github.com/wkhtmltopdf/packaging/releases/download

# Configure APT mirror (if set, replace default Debian sources)
RUN if [ -n "${APT_MIRROR}" ]; then \
      sed -i "s|deb.debian.org|${APT_MIRROR}|g" /etc/apt/sources.list.d/debian.sources 2>/dev/null || \
      sed -i "s|deb.debian.org|${APT_MIRROR}|g" /etc/apt/sources.list 2>/dev/null || true; \
    fi

RUN useradd -ms /bin/bash frappe \
    && apt-get update \
    && apt-get install --no-install-recommends -y \
    curl \
    git \
    vim \
    nginx \
    gettext-base \
    file \
    # weasyprint dependencies
    libpango-1.0-0 \
    libharfbuzz0b \
    libpangoft2-1.0-0 \
    libpangocairo-1.0-0 \
    #Chromium
    chromium-headless-shell \
    # For backups
    restic \
    gpg \
    # MariaDB
    mariadb-client \
    less \
    # redis-cli for configurator bootstrap (flush stale asset cache)
    redis-tools \
    # Postgres
    libpq-dev \
    postgresql-client \
    # For healthcheck
    wait-for-it \
    jq \
    # For MIME type detection
    media-types \
    # NodeJS
    && mkdir -p ${NVM_DIR} \
    && curl -o- ${NVM_INSTALL_SCRIPT} | bash \
    && . ${NVM_DIR}/nvm.sh \
    && if [ -n "${NODE_MIRROR}" ]; then export NVM_NODEJS_ORG_MIRROR=${NODE_MIRROR}; fi \
    && nvm install ${NODE_VERSION} \
    && nvm use v${NODE_VERSION} \
    && if [ -n "${NPM_REGISTRY}" ]; then npm config set registry ${NPM_REGISTRY}; fi \
    && npm install -g yarn \
    && nvm alias default v${NODE_VERSION} \
    && rm -rf ${NVM_DIR}/.cache \
    && echo 'export NVM_DIR="/home/frappe/.nvm"' >>/home/frappe/.bashrc \
    && echo '[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm' >>/home/frappe/.bashrc \
    && echo '[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion' >>/home/frappe/.bashrc \
    # Install wkhtmltopdf with patched qt
    && if [ "$(uname -m)" = "aarch64" ]; then export ARCH=arm64; fi \
    && if [ "$(uname -m)" = "x86_64" ]; then export ARCH=amd64; fi \
    && downloaded_file=wkhtmltox_${WKHTMLTOPDF_VERSION}.${WKHTMLTOPDF_DISTRO}_${ARCH}.deb \
    && curl -sLO ${WKHTMLTOPDF_MIRROR}/$WKHTMLTOPDF_VERSION/$downloaded_file \
    && apt-get install -y ./$downloaded_file \
    && rm $downloaded_file \
    # Clean up
    && rm -rf /var/lib/apt/lists/* \
    && rm -fr /etc/nginx/sites-enabled/default \
    && mkdir -p /etc/nginx/snippets \
    && pip3 install ${PIP_INDEX_URL:+--index-url ${PIP_INDEX_URL}} ${PIP_TRUSTED_HOST:+--trusted-host ${PIP_TRUSTED_HOST}} frappe-bench \
    # Fixes for non-root nginx and logs to stdout
    && sed -i '/user www-data/d' /etc/nginx/nginx.conf \
    && ln -sf /dev/stdout /var/log/nginx/access.log && ln -sf /dev/stderr /var/log/nginx/error.log \
    && touch /run/nginx.pid \
    && chown -R frappe:frappe /etc/nginx/conf.d \
    && chown -R frappe:frappe /etc/nginx/nginx.conf \
    && chown -R frappe:frappe /etc/nginx/snippets \
    && chown -R frappe:frappe /var/log/nginx \
    && chown -R frappe:frappe /var/lib/nginx \
    && chown -R frappe:frappe /run/nginx.pid \
    && chmod 755 /usr/local/bin/nginx-entrypoint.sh \
    && chmod 755 /usr/local/bin/configurator-init.sh \
    && chmod 644 /templates/nginx/frappe.conf.template


FROM base AS builder

RUN apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get install --no-install-recommends -y \
    # For frappe framework
    wget \
    #for building arm64 binaries
    libcairo2-dev \
    libpango1.0-dev \
    libjpeg-dev \
    libgif-dev \
    librsvg2-dev \
    # For psycopg2
    libpq-dev \
    # Other
    libffi-dev \
    liblcms2-dev \
    libldap2-dev \
    libmariadb-dev \
    libsasl2-dev \
    libtiff5-dev \
    libwebp-dev \
    pkg-config \
    redis-tools \
    rlwrap \
    tk8.6-dev \
    cron \
    # For pandas
    gcc \
    build-essential \
    libbz2-dev \
    && rm -rf /var/lib/apt/lists/*

# Copy apps manifest (remote apps)
COPY build/apps.json /opt/frappe/apps.json
RUN mkdir -p /opt/frappe && chown -R frappe:frappe /opt/frappe

# GitHub proxy: prefix GitHub URLs for China deployment (e.g. https://ghfast.top/)
ARG GITHUB_PROXY
RUN if [ -n "${GITHUB_PROXY}" ]; then \
      sed -i "s|https://github.com/|${GITHUB_PROXY}https://github.com/|g" /opt/frappe/apps.json; \
    fi

USER frappe

# Avoid HTTP/2 framing issues with some proxies/mirrors
# Also redirect github.com git requests through proxy (yarn install uses git:// for some deps)
ARG GITHUB_PROXY
RUN git config --global http.version HTTP/1.1 \
    && if [ -n "${GITHUB_PROXY}" ]; then \
         git config --global url."${GITHUB_PROXY}https://github.com/".insteadOf "https://github.com/"; \
       fi

# Re-declare mirror args for builder stage
ARG PIP_INDEX_URL
ARG PIP_TRUSTED_HOST
ARG NPM_REGISTRY

# Persist pip mirror config for bench init (which runs pip install internally)
RUN if [ -n "${PIP_INDEX_URL}" ]; then \
      mkdir -p /home/frappe/.config/pip \
      && printf '[global]\nindex-url = %s\ntrusted-host = %s\n' \
         "${PIP_INDEX_URL}" "${PIP_TRUSTED_HOST:-}" \
         > /home/frappe/.config/pip/pip.conf; \
    fi

# Persist npm mirror config for bench build (which runs npm/yarn internally)
RUN if [ -n "${NPM_REGISTRY}" ]; then \
      echo "registry=${NPM_REGISTRY}" > /home/frappe/.npmrc \
      && yarn config set registry "${NPM_REGISTRY}" 2>/dev/null || true; \
    fi

ARG FRAPPE_BRANCH=version-16
ARG FRAPPE_PATH=https://github.com/frappe/frappe
# cache mount: 即使 Docker 层缓存失效，pip/yarn 下载缓存仍然保留
RUN --mount=type=cache,target=/home/frappe/.cache/pip,uid=1000 \
    --mount=type=cache,target=/home/frappe/.cache/yarn,uid=1000 \
    bench init \
    --apps_path=/opt/frappe/apps.json \
    --frappe-branch=${FRAPPE_BRANCH} \
    --frappe-path=${GITHUB_PROXY:+${GITHUB_PROXY}}${FRAPPE_PATH} \
    --no-procfile \
    --no-backups \
    --skip-redis-config-generation \
    --verbose \
    /home/frappe/frappe-bench \
  && cd /home/frappe/frappe-bench \
  && echo '{"socketio_port":"9000"}' > sites/common_site_config.json \
  && find apps -mindepth 1 -path "*/.git" | xargs rm -fr

# Copy local custom apps (from apps/ directory in the mono-repo)
COPY --chown=frappe:frappe apps/ /opt/frappe/local-apps/

# Install each local custom app into the bench, then build frontend assets
RUN --mount=type=cache,target=/home/frappe/.cache/pip,uid=1000 \
    --mount=type=cache,target=/home/frappe/.cache/yarn,uid=1000 \
    cd /home/frappe/frappe-bench \
  && for app_dir in /opt/frappe/local-apps/*/; do \
       app_name=$(basename "$app_dir"); \
       if [ -f "$app_dir/setup.py" ] || [ -f "$app_dir/pyproject.toml" ]; then \
         echo "Installing local app: $app_name"; \
         cp -r "$app_dir" "apps/$app_name" \
         && /home/frappe/frappe-bench/env/bin/pip install -e "apps/$app_name" \
         && printf '\n%s\n' "$app_name" >> sites/apps.txt; \
       fi; \
     done \
  && bench build \
  && cp -r /home/frappe/frappe-bench/sites/assets /home/frappe/frappe-bench/sites-assets


FROM base AS backend

USER frappe

COPY --from=builder --chown=frappe:frappe /home/frappe/frappe-bench /home/frappe/frappe-bench

WORKDIR /home/frappe/frappe-bench

VOLUME [ \
  "/home/frappe/frappe-bench/sites", \
  "/home/frappe/frappe-bench/logs" \
]

CMD [ \
  "/home/frappe/frappe-bench/env/bin/gunicorn", \
  "--chdir=/home/frappe/frappe-bench/sites", \
  "--bind=0.0.0.0:8000", \
  "--threads=4", \
  "--workers=2", \
  "--worker-class=gthread", \
  "--worker-tmp-dir=/dev/shm", \
  "--timeout=120", \
  "--preload", \
  "frappe.app:application" \
]
