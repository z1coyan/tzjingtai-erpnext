# === Image ===
CUSTOM_IMAGE=synie-erpnext
CUSTOM_TAG=latest
PULL_POLICY=never

# === Frappe ===
FRAPPE_BRANCH=version-16

# === Database ===
DB_PASSWORD=changeme

# === Site ===
SITE_NAME=erp.localhost
ADMIN_PASSWORD=admin

# === Network ===
HTTP_PUBLISH_PORT=8080
HTTPS_PUBLISH_PORT=443

# === HTTPS (only with compose.https.yaml overlay) ===
# LETSENCRYPT_EMAIL=mail@example.com
# SITES_RULE=Host(`erp.example.com`)

# === Frontend (leave empty for defaults) ===
# FRAPPE_SITE_NAME_HEADER=
# UPSTREAM_REAL_IP_ADDRESS=
# UPSTREAM_REAL_IP_HEADER=
# UPSTREAM_REAL_IP_RECURSIVE=
# PROXY_READ_TIMEOUT=
# CLIENT_MAX_BODY_SIZE=

# === Docker Mirror (China) ===
# Uncomment the following lines to use Chinese mirrors for faster builds
#
# Registry mirror prefix for Docker Hub images (mariadb, redis, traefik)
# Examples: docker.1ms.run/ , docker.m.daocloud.io/library/
# REGISTRY_MIRROR=docker.1ms.run/
#
# Build-time mirrors (APT, pip, npm, etc.)
# APT_MIRROR=mirrors.aliyun.com
# PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
# PIP_TRUSTED_HOST=mirrors.aliyun.com
# NPM_REGISTRY=https://registry.npmmirror.com
# NVM_SOURCE=https://gitee.com/mirrors/nvm/raw/v0.39.5/install.sh
# WKHTMLTOPDF_MIRROR=https://mirror.ghproxy.com/https://github.com/wkhtmltopdf/packaging/releases/download
