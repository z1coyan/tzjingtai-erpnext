msgid "Sub-bill starting number; leave blank for legacy paper bills"
msgstr "子票起始号；老纸票留空"

msgid "Sub-bill ending number; leave blank for legacy paper bills"
msgstr "子票终止号；老纸票留空"

msgid "Must match an existing held segment on the bill"
msgstr "必须与承兑上一个在持有中的段精确匹配"

msgid "Amount must be greater than zero"
msgstr "金额必须大于零"

msgid "Amount {0} exceeds bill face amount {1}"
msgstr "金额 {0} 超过票面金额 {1}"

msgid "Segment From and Segment To are required for electronic bills"
msgstr "电子票必须填写子票起始号和终止号"

msgid "For electronic bills: must equal (Segment To - Segment From + 1) / 100"
msgstr "电子票：金额必须等于（子票终止号 - 起始号 + 1）/ 100"

msgid "Amount {0} does not match sub-bill range {1}-{2}; expected {3}"
msgstr "金额 {0} 与子票区间 {1}-{2} 不匹配，应为 {3}"

msgid "Sub-bill number cannot be empty"
msgstr "子票号不能为空"

msgid "Sub-bill number {0} is not a valid integer"
msgstr "子票号 {0} 不是合法整数"

msgid "Segment To ({0}) must be >= Segment From ({1})"
msgstr "子票终止号 ({0}) 必须大于等于起始号 ({1})"

msgid "New range {0}-{1} overlaps with existing held segment {2}-{3}"
msgstr "新区间 {0}-{1} 与已持有段 {2}-{3} 重叠"

msgid "Target range {0}-{1} is not fully contained in a single held segment"
msgstr "目标区间 {0}-{1} 未完整落在某一个持有段内"

msgid "No held segment contains range {0}-{1}"
msgstr "没有持有段包含区间 {0}-{1}"

msgid "No legacy held segment with amount {0} found"
msgstr "未找到金额为 {0} 的旧版承兑汇票持有段"

msgid "Legacy bill {0} already exists. Legacy bills cannot be received more than once."
msgstr "旧版承兑汇票 {0} 已存在。旧版承兑汇票不允许多次接收。"

msgid "Legacy bills must be received in full: amount {0} must equal face amount {1}"
msgstr "旧版承兑汇票必须整张接收：金额 {0} 必须等于票面金额 {1}"

msgid "Legacy bills cannot be split. Amount {0} must equal the current outstanding holding {1}."
msgstr "旧版承兑汇票不允许拆分。金额 {0} 必须等于当前持有 {1}。"

msgid "Legacy bills cannot be split; provide exactly one row with the full amount"
msgstr "旧版承兑汇票不允许拆分，只能有一行金额等于整张未结余额"

msgid "Current Holdings"
msgstr "当前持有段"

msgid "Select a bill to see current holdings"
msgstr "先选一张承兑才会显示其持有段"

msgid "No held segments on this bill"
msgstr "该承兑当前无持有段"

msgid "Bill {0} · Face {1} · Outstanding {2}"
msgstr "承兑 {0} · 票面 {1} · 当前持有 {2}"

