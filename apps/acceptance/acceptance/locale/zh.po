#. ---- Description text ----

msgid "30-digit number"
msgstr "30位阿拉伯数字"

msgid "0 means non-splittable"
msgstr "0表示不可拆分"

msgid "Auto-calculated = (End - Start + 1) x 0.01"
msgstr "自动计算 = (结束号 - 起始号 + 1) × 0.01"

#. ---- Validation messages (Python) ----

msgid "Bill number must be 30 digits starting with 5 (bank), 6 (commercial), 7 (supply chain commercial) or 8 (supply chain bank)"
msgstr "票据包号必须为30位数字，且首位为5（银票）、6（商票）、7（供应链商票）或8（供应链银票）"

msgid "Bill number must be 30 digits starting with 5/6/7/8"
msgstr "票据包号必须为30位数字，且首位为5/6/7/8"

msgid "Due date must be after issue date"
msgstr "到期日期必须晚于出票日期"

msgid "This bill is non-splittable (sub ticket range is 0)"
msgstr "该票据不可拆分（子票区间为0）"

msgid "Split amount must be a multiple of 0.01"
msgstr "拆分金额必须为0.01的整数倍"

msgid "Split amount must be less than bill amount"
msgstr "拆分金额必须小于票面金额"

msgid "Split amount must be greater than 0"
msgstr "拆分金额必须大于0"

msgid "Total amount after split does not match original bill amount"
msgstr "拆分后金额之和不等于原票面金额，请检查"

msgid "Sub ticket range is 0, this bill is non-splittable"
msgstr "子票区间为0，该票据不可拆分"

msgid "Bill of Exchange created: {0}"
msgstr "已创建票据台账：{0}"

msgid "Only bills with status 'Received - Circulating' can be transferred, current status: {0}"
msgstr "只能转让状态为「已收票-可流通」的票据，当前状态为：{0}"

msgid "This bill is marked as 'No Transfer', endorsement transfer is not allowed"
msgstr "该票据已标记「不得转让」，无法进行背书转让"

msgid "Transfer amount cannot exceed bill amount"
msgstr "转让金额不能大于票面金额"

msgid "This bill is non-splittable, partial transfer is not allowed"
msgstr "该票据不可拆分，无法部分转让"

msgid "Only bills with status 'Received - Circulating' can be discounted, current status: {0}"
msgstr "只能贴现状态为「已收票-可流通」的票据，当前状态为：{0}"

msgid "Discount date must be before due date"
msgstr "贴现日期必须早于到期日期"

msgid "Only bills with status 'Received - Circulating' or 'Payment Pending' can be redeemed, current status: {0}"
msgstr "只能兑付状态为「已收票-可流通」或「提示付款中」的票据，当前状态为：{0}"

msgid "Payment amount must equal bill amount {0}"
msgstr "兑付金额必须等于票面金额 {0}"

msgid "OCR is not enabled, please configure in OCR Settings"
msgstr "OCR 功能未启用，请在 OCR 设置中配置"

