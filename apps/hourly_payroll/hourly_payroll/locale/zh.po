msgstr "新建打卡数"

msgid "Skipped Duplicates"
msgstr "跳过重复"

msgid "Skipped Unmapped"
msgstr "跳过未映射"

msgid "Records whose device user id has no matching Employee"
msgstr "设备用户号在员工表中没有匹配的记录数"

msgid "Options"
msgstr "选项"

msgid "Auto Create Unknown Employees"
msgstr "自动新建未知员工"

msgid "When enabled, a placeholder Employee will be created for any device user id that is not yet mapped"
msgstr "启用后，遇到未映射的设备用户号会自动建一条占位员工记录"

msgid "Default Company"
msgstr "默认公司"

msgid "Company assigned to auto-created placeholder employees"
msgstr "自动新建占位员工时所属的公司"

msgid "Created Employees"
msgstr "新建员工数"

msgid "Placeholder employees created for previously unmapped device user ids"
msgstr "为此前未映射的设备用户号自动新建的占位员工数量"

msgid "Default Company is required when Auto Create Unknown Employees is enabled"
msgstr "勾选「自动新建未知员工」后，必须填写默认公司"

msgid "Created placeholder Employee {0} for device user id {1}"
msgstr "已为设备用户号 {1} 新建占位员工 {0}"

msgid "Log"
msgstr "日志"

#. Attlog Import — select options
msgid "Draft"
msgstr "草稿"

msgid "Imported"
msgstr "已导入"

msgid "Failed"
msgstr "失败"

#. Attlog Import — messages
msgid "Please attach an attlog file first"
msgstr "请先上传考勤文件"

msgid "Unmapped device user ids: {0}"
msgstr "未映射的设备用户号：{0}"

msgid "Parse & Create Checkins"
msgstr "解析并创建打卡"

msgid "Parse the attlog file and create Employee Checkin records?"
msgstr "确认解析考勤文件并批量创建员工打卡记录？"

msgid "Import Finished"
msgstr "导入完成"

msgid "Total: {0} · Created: {1} · New Employees: {2} · Duplicates: {3} · Unmapped: {4}"
msgstr "共 {0} 条，新建打卡 {1}，新建员工 {2}，重复 {3}，未映射 {4}"

