#. Hourly Payroll Settings — fields
msgid "Morning Start"
msgstr "上午上班"

msgid "Morning End"
msgstr "上午下班"

msgid "Afternoon Start"
msgstr "下午上班"

msgid "Afternoon End"
msgstr "下午下班"

msgid "Overtime Start"
msgstr "加班开始"

msgid "Overtime End"
msgstr "加班结束"

msgid "Window Buffer Minutes"
msgstr "时间窗容差（分钟）"

msgid "Tolerance in minutes for a checkin to be counted in a window"
msgstr "打卡被归入某个时间窗的前后容差分钟数"

msgid "Extra Minutes"
msgstr "附加分钟"

msgid "Minutes added to raw worked duration before rounding"
msgstr "截断前，对原始工时额外累加的分钟数"

msgid "Round Unit Hours"
msgstr "截断单位（小时）"

msgid "Hours truncated down to multiples of this unit"
msgstr "工时按此单位向下取整"

msgid "Regular Cap Hours"
msgstr "正班封顶（小时）"

msgid "Maximum regular hours counted per day (morning + afternoon)"
msgstr "每日正班（上午+下午）累计封顶小时数"

msgid "Overtime Full Threshold Hours"
msgstr "加班全勤阈值（小时）"

msgid "Overtime worked hours at or above this value qualifies for full credit"
msgstr "加班净时长达到此值即按全勤奖励计算"

msgid "Overtime Full Credit Hours"
msgstr "加班全勤奖励（小时）"

msgid "Hours credited when overtime is fully attended"
msgstr "加班全勤时实际计入的工时"

msgid "Overtime Full Tolerance Minutes"
msgstr "加班全勤容差（分钟）"

msgid "Minutes shortfall still considered fully attended"
msgstr "差多少分钟以内仍视为加班全勤"

msgid "Regular Hours Per Day"
msgstr "日标准工时"

msgid "Divisor used to derive hourly rate from daily wage"
msgstr "由日薪推算时薪时使用的每日标准工时"

#. Hourly Payroll Settings — Shift Integration
msgid "Shift Integration"
msgstr "班次对接"

msgid "Create a Shift Type from these time windows and bind it to every Active Employee's Default Shift. This lets ERPNext native Auto Attendance generate daily Attendance records from Employee Checkins."
msgstr "根据以上时间窗创建一个班次，并绑定到所有在职员工的默认班次。ERPNext 的自动考勤会据此从员工打卡自动生成每日考勤记录。"

msgid "Shift Type Name"
msgstr "班次名称"

msgid "Name of the Shift Type created/updated by the Setup button"
msgstr "点击「一键配置」按钮时创建/更新的 Shift Type 名称"

msgid "Linked Shift Type"
msgstr "已绑定班次"

msgid "Populated after you click Setup. New placeholder employees are bound to this shift on creation."
msgstr "点击「一键配置」后自动填入；后续自动新建的占位员工会绑定到此班次。"

msgid "Auto Attendance Process From"
msgstr "自动考勤起始日"

msgid "The Shift Type's Process Attendance After date. Set to a date before your earliest Checkin so Auto Attendance can backfill historical records."
msgstr "班次的自动考勤处理起始日期。设为早于最早一条打卡的日期，自动考勤就能回溯历史打卡。"

msgid "Setup Shift & Assignments"
msgstr "一键配置班次与绑定"

msgid "Leave empty to bind every Active employee across all companies"
msgstr "留空表示绑定所有公司的在职员工"

msgid "Company"
msgstr "公司"

msgid "Run"
msgstr "运行"

msgid "Shift Setup Finished"
msgstr "班次配置完成"

msgid "Shift Type: {0}<br>Created: {1} · Updated: {2}<br>Employees bound: {3} · Already bound: {4}"
msgstr "班次：{0}<br>新建：{1} · 更新：{2}<br>本次绑定员工：{3} · 原已绑定：{4}"

msgid "Open Shift Type"
msgstr "打开班次"

msgid "Morning Start and Afternoon End (or Overtime End) must be set first"
msgstr "请先填写上午上班时间和下午下班时间（或加班结束时间）"

