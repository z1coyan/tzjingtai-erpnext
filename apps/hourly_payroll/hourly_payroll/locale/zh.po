msgid "Basic Wage + Adjustment"
msgstr "基本工资 + 补正"

msgid "A Monthly Payroll Run for {0} {1}-{2:02d} already exists: {3}"
msgstr "公司 {0} 的 {1}-{2:02d} 月度薪资运算已存在：{3}"

#. Payroll Adjustment — fields & messages
msgid "Title"
msgstr "标题"

msgid "A readable name for this adjustment run (e.g. 春节奖金发放 / 3月份补发)"
msgstr "自定义标题，便于区分用途（如：春节奖金发放 / 3月份补发）"

msgid "Posting date used on the Journal Entry"
msgstr "凭证的记账日期"

msgid "Notes"
msgstr "说明"

msgid "Description"
msgstr "说明内容"

msgid "Total Bonus"
msgstr "奖金合计"

msgid "Total Supplementary"
msgstr "补发合计"

msgid "Adjustment Type"
msgstr "类型"

msgid "Supplementary"
msgstr "补发"

msgid "Bonus"
msgstr "奖金"

msgid "Remark"
msgstr "备注"

msgid "On submit, a Draft Journal Entry will be auto-created: Dr Wage Expense per employee / Cr Payroll Payable total."
msgstr "提交时自动生成一张草稿状态的会计凭证：按员工逐行借记工资费用、贷记应付工资合计。"

msgid "Cannot submit with empty details"
msgstr "明细为空，无法提交"

msgid "Row {0}: Amount must be greater than zero"
msgstr "第 {0} 行：金额必须大于 0"

msgid "{0} · {1} · {2}: {3}"
msgstr "{0} · {1} · {2}：{3}"

msgid "Payroll Adjustment {0} · {1} ({2}-{3:02d})"
msgstr "工资补发/奖金发放 {0} · {1}（{2}-{3:02d}）"

#. Payroll Summary Report
msgid "Total Paid"
msgstr "总发放"

msgid "Period"
msgstr "期间"

msgid "Please select Company and Period Year"
msgstr "请先选择公司和薪资年份"

#. Custom Field (Attendance / Employee)
msgid "Net Work Hours"
msgstr "净工时"

msgid "Used by Hourly Payroll: hourly rate = daily_wage / regular_hours_per_day"
msgstr "工时薪资使用：时薪 = 日薪 / 日标准工时"

#. Monthly Payroll Run — buttons & messages
msgid "Generate"
msgstr "生成"

msgid "Export Details (Excel)"
msgstr "导出明细（Excel）"

msgid "No."
msgstr "序号"

msgid "Total"
msgstr "合计"

msgid "Missing Fields"
msgstr "字段未填"

msgid "Please fill Company, Period Year and Period Month first."
msgstr "请先填写公司、薪资年份和薪资月份。"

msgid "Recalculate details for {0}-{1}?"
msgstr "确认重新计算 {0}-{1} 的薪资明细？"

msgid "Generated {0} rows, total {1}"
msgstr "已生成 {0} 条明细，合计 {1}"

msgid "Only Draft payroll runs can be regenerated"
msgstr "仅草稿状态的薪资运算可以重新生成"

msgid "Cannot submit an empty payroll run. Click Generate first."
msgstr "明细为空，无法提交，请先点击「生成」。"

msgid "Period Year and Period Month must be integers"
msgstr "薪资年份和薪资月份必须是整数"

#. Hourly Payroll Settings — validate messages
msgid "Morning End must be later than Morning Start"
msgstr "上午下班时间必须晚于上午上班时间"

msgid "Afternoon End must be later than Afternoon Start"
msgstr "下午下班时间必须晚于下午上班时间"

msgid "Overtime End must be later than Overtime Start"
msgstr "加班结束时间必须晚于加班开始时间"

msgid "Round Unit Hours must be positive"
msgstr "截断单位必须大于 0"

msgid "Regular Hours Per Day must be positive"
msgstr "日标准工时必须大于 0"
