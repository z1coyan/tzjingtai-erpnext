#. Monthly Payroll Run — Accounting
msgid "Accounting"
msgstr "会计"

msgid "When this payroll run is submitted, a Draft Journal Entry will be auto-created (Dr Wage Expense per employee / Cr Payroll Payable total) for accounting review before manual submission."
msgstr "当此月度薪资单提交时，会自动生成一张草稿状态的会计凭证（按员工逐行借记工资费用、贷记应付工资合计），待会计复核无误后再手动提交。"

msgid "Posting Date"
msgstr "记账日期"

msgid "Posting date of the Journal Entry. Defaults to the last day of the payroll month."
msgstr "凭证的记账日期，默认取薪资月的最后一天。"

msgid "Wage Expense Account"
msgstr "工资费用科目"

msgid "Debit side: salary/wage expense GL account"
msgstr "借方：工资费用总账科目"

msgid "Payroll Payable Account"
msgstr "应付工资科目"

msgid "Credit side: payable/liability GL account that will be settled when wages are actually paid"
msgstr "贷方：应付工资/负债类总账科目，实际发薪时再冲销"

msgid "Cost Center"
msgstr "成本中心"

msgid "Cost center used on every Journal Entry line. Defaults to the company's default cost center."
msgstr "用于凭证每一行的成本中心，默认取公司的默认成本中心。"

msgid "Journal Entry"
msgstr "会计凭证"

msgid "Auto-created on submit"
msgstr "提交时自动创建（草稿状态，需会计复核后手动提交）"

msgid "Open Journal Entry"
msgstr "打开凭证"

#. Submit-time validations & remarks
msgid "Wage Expense Account and Payroll Payable Account are required to submit"
msgstr "提交前必须填写工资费用科目和应付工资科目"

msgid "Wage Expense Account and Payroll Payable Account must be different"
msgstr "工资费用科目和应付工资科目必须不同"

msgid "No payable amount in details; nothing to post"
msgstr "明细中没有可入账金额，无需生成凭证"

msgid "{0} · {1} · {2} hrs"
msgstr "{0} · {1} · {2} 小时"

msgid "Hourly Payroll Run {0} ({1}-{2:02d})"
msgstr "工时薪资 {0}（{1}-{2:02d}）"

